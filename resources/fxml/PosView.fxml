<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<HBox xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.databrew.cafe.controller.PosController"
      spacing="0" styleClass="pos-root">

  <!-- ========== LEFT: Menu Browser (grows to fill) ========== -->
  <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="pos-menu-panel">
    <padding><Insets top="18" right="22" bottom="18" left="22" /></padding>

    <!-- Header row: category left, search right -->
    <HBox spacing="12" alignment="CENTER" styleClass="pos-menu-header">
      <padding><Insets top="0" right="0" bottom="14" left="0" /></padding>
      <ComboBox fx:id="categoryCombo" styleClass="pos-category-combo" prefWidth="220" prefHeight="42" promptText="All Categories" />
      <Pane HBox.hgrow="ALWAYS" />
      <TextField fx:id="searchField" promptText="Search menu items..." styleClass="pos-search-field" prefWidth="280" prefHeight="42" />
    </HBox>

    <!-- Scrollable item card grid -->
    <ScrollPane fx:id="menuScrollPane" fitToWidth="true" fitToHeight="false" pannable="true"
                VBox.vgrow="ALWAYS" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                styleClass="pos-menu-scroll">
      <FlowPane fx:id="menuFlowPane" hgap="16" vgap="16" alignment="TOP_LEFT" styleClass="pos-menu-flow">
        <padding><Insets top="6" right="6" bottom="6" left="6" /></padding>
      </FlowPane>
    </ScrollPane>
  </VBox>

  <!-- ========== RIGHT: Cart / Current Order (glassmorphism) ========== -->
  <ScrollPane fx:id="cartScrollPane" fitToWidth="true" fitToHeight="true" pannable="true"
              hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" prefWidth="470"
              styleClass="pos-cart-scroll">
  <VBox spacing="10" styleClass="pos-cart-panel">
    <padding><Insets top="16" right="18" bottom="16" left="18" /></padding>

    <!-- Cart title -->
    <Label text="Current Order" styleClass="pos-cart-title" />

    <!-- Customer / discount / tax form (compact) -->
    <GridPane hgap="10" vgap="8" styleClass="pos-cart-form">
      <columnConstraints>
        <ColumnConstraints percentWidth="36" />
        <ColumnConstraints percentWidth="64" />
      </columnConstraints>

      <Label text="Customer" styleClass="pos-cart-label" GridPane.rowIndex="0" GridPane.columnIndex="0" />
      <TextField fx:id="customerField" promptText="Walk-in" styleClass="pos-cart-field" GridPane.rowIndex="0" GridPane.columnIndex="1" />

      <Label text="Type" styleClass="pos-cart-label" GridPane.rowIndex="1" GridPane.columnIndex="0" />
      <ComboBox fx:id="customerTypeCombo" styleClass="pos-cart-field" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity" />

      <Label text="Discount" styleClass="pos-cart-label" GridPane.rowIndex="2" GridPane.columnIndex="0" />
      <ComboBox fx:id="discountCombo" styleClass="pos-cart-field" GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="Infinity" promptText="No Discount" />

      <Label text="Tax" styleClass="pos-cart-label" GridPane.rowIndex="3" GridPane.columnIndex="0" />
      <ComboBox fx:id="taxCombo" styleClass="pos-cart-field" GridPane.rowIndex="3" GridPane.columnIndex="1" maxWidth="Infinity" promptText="No Tax" />

      <Label text="Payment" styleClass="pos-cart-label" GridPane.rowIndex="4" GridPane.columnIndex="0" />
      <ComboBox fx:id="methodCombo" styleClass="pos-cart-field" GridPane.rowIndex="4" GridPane.columnIndex="1" maxWidth="Infinity">
        <items>
          <FXCollections fx:factory="observableArrayList">
            <String fx:value="CASH" />
            <String fx:value="CARD" />
            <String fx:value="MFS" />
          </FXCollections>
        </items>
      </ComboBox>
    </GridPane>

    <!-- Cart items table (primary focus, scrollable) -->
    <TableView fx:id="cartTable" VBox.vgrow="ALWAYS" styleClass="pos-cart-table" minHeight="280">
      <columns>
        <TableColumn fx:id="cartItemCol" text="Item" prefWidth="148" />
        <TableColumn fx:id="cartQtyCol" text="Qty" prefWidth="48" />
        <TableColumn fx:id="cartPriceCol" text="Price" prefWidth="72" />
        <TableColumn fx:id="cartTotalCol" text="Total" prefWidth="78" />
        <TableColumn fx:id="cartActionsCol" text="" prefWidth="55" />
      </columns>
      <placeholder>
        <Label text="Cart is empty" styleClass="pos-cart-empty" />
      </placeholder>
    </TableView>

    <!-- Cart action buttons row -->
    <HBox spacing="8" alignment="CENTER" styleClass="pos-cart-actions">
      <Button text="+ Qty" onAction="#onIncreaseQty" styleClass="pos-btn-action pos-btn-plus" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
      <Button text="- Qty" onAction="#onDecreaseQty" styleClass="pos-btn-action pos-btn-minus" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
      <Button text="Remove" onAction="#onRemoveItem" styleClass="pos-btn-action pos-btn-remove" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
      <Button text="Clear" onAction="#onClearCart" styleClass="pos-btn-action pos-btn-clear" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
    </HBox>

    <!-- Totals panel -->
    <VBox spacing="5" styleClass="pos-totals-box">
      <HBox>
        <Label text="Subtotal" styleClass="pos-totals-label" />
        <Pane HBox.hgrow="ALWAYS" />
        <Label fx:id="subtotalLabel" text="\$0.00" styleClass="pos-totals-value" />
      </HBox>
      <HBox>
        <Label text="Discount" styleClass="pos-totals-label pos-discount-text" />
        <Pane HBox.hgrow="ALWAYS" />
        <Label fx:id="discountLabel" text="-\$0.00" styleClass="pos-totals-value pos-discount-text" />
      </HBox>
      <HBox>
        <Label text="Tax" styleClass="pos-totals-label pos-tax-text" />
        <Pane HBox.hgrow="ALWAYS" />
        <Label fx:id="taxLabel" text="+\$0.00" styleClass="pos-totals-value pos-tax-text" />
      </HBox>
      <Separator />
      <HBox alignment="CENTER_LEFT">
        <Label text="TOTAL" styleClass="pos-total-big-label" />
        <Pane HBox.hgrow="ALWAYS" />
        <Label fx:id="totalLabel" text="\$0.00" styleClass="pos-total-big-value" />
      </HBox>
    </VBox>

    <!-- CHECKOUT — most prominent button -->
    <Button text="Checkout" onAction="#onCheckout" maxWidth="Infinity" styleClass="pos-checkout-btn" />
  </VBox>
  </ScrollPane>
</HBox>
